<?php
require_once __DIR__ . '/../includes/init.php';

require_admin();

$pageTitle = 'Category Management';

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    if (!verify_csrf()) {
        set_flash('danger', 'Invalid form token. Please try again.');
        redirect('admin/categories.php');
    }

    $action = (string) ($_POST['action'] ?? '');
    $id = (int) ($_POST['id'] ?? 0);

    try {
        if ($action === 'create') {
            $stmt = db()->prepare('INSERT INTO categories (name, description, status, created_at) VALUES (:name, :description, :status, CURRENT_TIMESTAMP)');
            $stmt->execute([
                'name' => trim((string) ($_POST['name'] ?? '')),
                'description' => trim((string) ($_POST['description'] ?? '')),
                'status' => (string) ($_POST['status'] ?? 'active'),
            ]);
            log_activity((int) current_user()['id'], current_user()['email'], 'Add category');
            set_flash('success', 'Category added.');
        } elseif ($action === 'update') {
            $stmt = db()->prepare('UPDATE categories SET name = :name, description = :description, status = :status WHERE id = :id');
            $stmt->execute([
                'name' => trim((string) ($_POST['name'] ?? '')),
                'description' => trim((string) ($_POST['description'] ?? '')),
                'status' => (string) ($_POST['status'] ?? 'active'),
                'id' => $id,
            ]);
            log_activity((int) current_user()['id'], current_user()['email'], 'Update category ID ' . $id);
            set_flash('success', 'Category updated.');
        } elseif ($action === 'delete') {
            $stmt = db()->prepare('DELETE FROM categories WHERE id = :id');
            $stmt->execute(['id' => $id]);
            log_activity((int) current_user()['id'], current_user()['email'], 'Delete category ID ' . $id);
            set_flash('success', 'Category deleted.');
        }
    } catch (Throwable $exception) {
        set_flash('danger', 'Category action failed. It may still be assigned to products.');
    }

    redirect('admin/categories.php');
}

$editCategory = null;
if (isset($_GET['edit'])) {
    $stmt = db()->prepare('SELECT * FROM categories WHERE id = :id LIMIT 1');
    $stmt->execute(['id' => (int) $_GET['edit']]);
    $editCategory = $stmt->fetch();
}

$categories = db()->query(
    'SELECT c.*, COUNT(p.id) AS product_count
     FROM categories c
     LEFT JOIN products p ON p.category_id = c.id
     GROUP BY c.id
     ORDER BY c.name'
)->fetchAll();

include __DIR__ . '/../templates/admin_header.php';
?>
<div class="row g-4">
    <div class="col-xl-4">
        <div class="card">
            <div class="card-body">
                <h2 class="h5 mb-3"><?= $editCategory ? 'Edit Category' : 'Add Category' ?></h2>
                <form method="post">
